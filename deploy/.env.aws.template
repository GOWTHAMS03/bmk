# ─────────────────────────────────────────────────────────────────────────────
# BusyMumKitchen – AWS Production Environment Variables
#
# INSTRUCTIONS:
#   1. Copy this file to .env  on your EC2 instance
#   2. Fill in every value marked <REPLACE>
#   3. chmod 600 .env  (restrict permissions)
#   4. NEVER commit this file to Git (already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── ECR Docker Image ──────────────────────────────────────────────────────────
# Format: <account_id>.dkr.ecr.<region>.amazonaws.com/<repo>:<tag>
ECR_IMAGE=<REPLACE: e.g. 123456789012.dkr.ecr.ap-south-1.amazonaws.com/bmk-backend:latest>

# ── AWS RDS PostgreSQL ─────────────────────────────────────────────────────────
# Get DB_HOST from RDS → Databases → your instance → Endpoint
DB_HOST=<REPLACE: e.g. bmk-db.xxxxxxxx.ap-south-1.rds.amazonaws.com>
DB_PORT=5432
DB_NAME=busymumkitchen
DB_USERNAME=bmk_user
DB_PASSWORD=<REPLACE: strong random password>

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from Atlas → Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/busymumkitchen_logs?retryWrites=true&w=majority

# ── RabbitMQ (Docker on EC2) ───────────────────────────────────────────────────
RABBITMQ_USER=bmk_rabbit
RABBITMQ_PASS=<REPLACE: strong random password>

# ── JWT Secret (min 64 chars) ─────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=<REPLACE: openssl rand -base64 64>

# ── AWS Credentials (for SNS OTP) ─────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY=<REPLACE: IAM user access key>
AWS_SECRET_KEY=<REPLACE: IAM user secret key>
AWS_SNS_ENABLED=true
AWS_SNS_SENDER_ID=BMKITCHN

# ── OTP Delivery: SMS | EMAIL | DEV ───────────────────────────────────────────
OTP_DELIVERY_METHOD=SMS

# ── Gmail SMTP (optional, for EMAIL OTP) ──────────────────────────────────────
# MAIL_USERNAME=your.email@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<REPLACE: sk_live_xxxxxxxx>
STRIPE_WEBHOOK_SECRET=<REPLACE: whsec_xxxxxxxx>
