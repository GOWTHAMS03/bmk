		{
			"name": "Orders",
			"description": "Order creation, listing, tracking with KFC-style daily order numbers.\n\nResponse includes `dailyOrderNumber` (e.g. `#001`), `estimatedPrepMinutes`, and kitchen timestamps.",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    if (json.data) {",
									"        if (json.data.id) pm.environment.set('orderId', json.data.id);",
									"        if (json.data.orderNumber) pm.environment.set('orderNumber', json.data.orderNumber);",
									"        if (json.data.dailyOrderNumber) pm.environment.set('dailyOrderNumber', json.data.dailyOrderNumber);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customerName\": \"Test User\",\n  \"customerPhone\": \"{{phoneNumber}}\",\n  \"deliveryAddress\": \"123 Main Street, Mumbai 400001\",\n  \"notes\": \"Ring the doorbell twice\",\n  \"paymentMethod\": \"COD\"\n}"
